{
  "manifest_version": 3,
  "name": "Tether Live Copilot",
  "version": "0.2.0",
  "description": "Tether real-time behavioral intervention overlay across websites.",
  "permissions": ["storage", "tabs", "activeTab", "notifications"],
  "icons": {
    "128": "icons/nudge-128.png"
  },
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Tether",
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
